# ─────────────────────────────────────────────────────────────────────────────
# Pest Control Rajshahi — BACKEND env template
# Copy to `.env` and fill in real values. `.env` is gitignored — never commit it.
# Keys marked (required) are validated on boot by src/config/env.validation.ts.
# ─────────────────────────────────────────────────────────────────────────────

# Runtime
NODE_ENV=development                 # development | production | test
PORT=3000
APP_NAME="Pest Control Rajshahi"     # (required)
COOKIE_PREFIX=pcr                    # (required) auth cookie namespace — do NOT share across apps

# Database — Neon Postgres (required). Use the POOLED url for DATABASE_URL and
# the direct (non-pooled) url for DIRECT_URL (Prisma migrations).
DATABASE_URL="postgresql://USER:PASSWORD@HOST-pooler.REGION.aws.neon.tech/DB?sslmode=require&channel_binding=require"
DIRECT_URL="postgresql://USER:PASSWORD@HOST.REGION.aws.neon.tech/DB?sslmode=require&channel_binding=require"

# Secrets — generate with: openssl rand -base64 48   (each must be >= 16 chars) (required)
JWT_ACCESS_SECRET=change_me_min_16_chars
JWT_REFRESH_SECRET=change_me_min_16_chars
OTP_JWT_SECRET=change_me_min_16_chars
INVITE_TOKEN_SECRET=change_me_min_16_chars
PREVIEW_TOKEN_SECRET=change_me_min_16_chars
COOKIE_SECRET=change_me_min_16_chars

# CORS — comma-separated list of allowed frontend origins.
# Dev: http://localhost:5173   Prod: https://your-frontend-domain.com
CORS_ORIGINS=http://localhost:5173

# Cross-subdomain auth (prod only). Set when frontend + backend share a parent
# domain so cookies work across them, e.g. .pestcontrolrajshahi.com. Leave blank
# locally and for unrelated domains (then SameSite=None;Secure is used in prod).
COOKIE_DOMAIN=

# Google OAuth (optional — enables "Sign in with Google"). Leave blank to disable.
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_CALLBACK_URL=http://localhost:3000/api/v1/auth/google/callback

# Cloudinary — media storage (required)
CLOUDINARY_CLOUD_NAME=your_cloud_name
CLOUDINARY_API_KEY=your_api_key
CLOUDINARY_API_SECRET=your_api_secret
CLOUDINARY_FOLDER=pestcontrolrajshahi

# Email / SMTP (optional). If MAIL_PASS is blank or starts with "replace_",
# emails are logged only (dry-run), not sent. Use a Gmail App Password for Gmail.
MAIL_HOST=smtp.gmail.com
MAIL_PORT=465
MAIL_USER=
MAIL_PASS=
MAIL_FROM="Pest Control Rajshahi <no-reply@pestcontrolrajshahi.com>"
ADMIN_NOTIFY_EMAIL=admin@pestcontrolrajshahi.com

# SMS / OTP — BulkSMSBD (optional). If the API key is blank or starts with
# "replace_", OTP runs in dry-run mode (code is logged, no SMS sent). A real key
# is REQUIRED for live customer registration.
BULKSMSBD_API_KEY=
BULKSMSBD_SENDER_ID=

# Public site URL — used in emails and OAuth redirects (required)
# Dev: http://localhost:5173   Prod: https://your-frontend-domain.com
PUBLIC_SITE_URL=http://localhost:5173

# Seed admin (used by `prisma db seed`) (required)
SEED_ADMIN_EMAIL=admin@pestcontrolrajshahi.com
SEED_ADMIN_PHONE=01700000001
SEED_ADMIN_PASSWORD=ChangeMe!2026

# Gemini (Google GenAI) — powers admin AI content/image generation.
# Leave GEMINI_API_KEY blank to disable the /admin/ai/* endpoints.
# GEMINI_TEXT_MODELS is a comma-separated fallback chain (left to right). Each model
# is retried GEMINI_MAX_RETRIES_PER_MODEL times before falling through to the next.
GEMINI_API_KEY=
GEMINI_TEXT_MODELS=gemini-3.5-flash,gemini-3.1-pro-preview,gemini-3.1-flash-lite,gemini-2.5-pro,gemini-3-flash-preview
GEMINI_IMAGE_MODELS=gemini-2.5-flash-image,gemini-3.1-flash-image,gemini-3-pro-image,gemini-3.1-flash-image-preview,nano-banana-pro-preview
GEMINI_MAX_RETRIES_PER_MODEL=3
