generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

// ─────────────────────────────────────────────────────────────
//  IDENTITY
// ─────────────────────────────────────────────────────────────

model User {
  id             String     @id @default(cuid())
  email          String?    @unique
  phone          String?    @unique
  username       String?    @unique
  passwordHash   String?
  emailVerified  Boolean    @default(false)
  phoneVerified  Boolean    @default(false)
  name           String
  avatar         String?
  role           Role       @default(CUSTOMER)
  status         UserStatus @default(ACTIVE)
  phoneChangedAt DateTime?
  lastLoginAt    DateTime?
  deletedAt      DateTime?
  createdAt      DateTime   @default(now())
  updatedAt      DateTime   @updatedAt

  oauthAccounts OAuthAccount[]
  sessions      Session[]
  orders        Order[]
  invitesSent   UserInvite[]   @relation("InvitedBy")

  @@index([role])
  @@index([deletedAt])
}

enum Role {
  SUPER_ADMIN
  ADMIN
  STAFF
  CUSTOMER
}

enum UserStatus {
  ACTIVE
  SUSPENDED
  PENDING_VERIFICATION
}

model OAuthAccount {
  id             String   @id @default(cuid())
  userId         String
  user           User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  provider       String
  providerUserId String
  email          String?
  createdAt      DateTime @default(now())

  @@unique([provider, providerUserId])
  @@index([userId])
}

model Session {
  id          String       @id @default(cuid())
  userId      String
  user        User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  refreshHash String
  userAgent   String?
  ip          String?
  scope       SessionScope
  expiresAt   DateTime
  revokedAt   DateTime?
  createdAt   DateTime     @default(now())

  @@index([userId])
  @@index([expiresAt])
}

enum SessionScope {
  ADMIN
  CUSTOMER
}

model UserInvite {
  id          String    @id @default(cuid())
  email       String?
  phone       String?
  role        Role
  tokenHash   String    @unique
  invitedById String
  invitedBy   User      @relation("InvitedBy", fields: [invitedById], references: [id])
  acceptedAt  DateTime?
  expiresAt   DateTime
  createdAt   DateTime  @default(now())
}

// ─────────────────────────────────────────────────────────────
//  CONTENT
// ─────────────────────────────────────────────────────────────

model ServiceCategory {
  id        String    @id @default(cuid())
  slug      String    @unique
  name      String
  icon      String?
  order     Int       @default(0)
  isVisible Boolean   @default(true)
  services  Service[]
}

model Service {
  id             String          @id @default(cuid())
  categoryId     String
  category       ServiceCategory @relation(fields: [categoryId], references: [id])
  slug           String          @unique
  name           String
  shortDesc      String
  longDesc       Json
  image          String?
  gallery        String[]
  basePrice      Decimal?        @db.Decimal(10, 2)
  priceUnit      String?
  featured       Boolean         @default(false)
  status         ContentStatus   @default(DRAFT)
  publishedAt    DateTime?
  order          Int             @default(0)
  faqs           Json?
  inclusions     String[]
  exclusions     String[]
  seoTitle       String?
  seoDescription String?
  seoImage       String?
  deletedAt      DateTime?
  createdAt      DateTime        @default(now())
  updatedAt      DateTime        @updatedAt
  orderItems     OrderItem[]

  @@index([status])
  @@index([deletedAt])
  @@index([categoryId])
}

model Project {
  id             String        @id @default(cuid())
  slug           String        @unique
  title          String
  client         String?
  category       String?
  summary        String
  body           Json
  cover          String?
  gallery        String[]
  date           DateTime?
  status         ContentStatus @default(DRAFT)
  publishedAt    DateTime?
  order          Int           @default(0)
  seoTitle       String?
  seoDescription String?
  seoImage       String?
  deletedAt      DateTime?
  createdAt      DateTime      @default(now())
  updatedAt      DateTime      @updatedAt

  @@index([status])
  @@index([deletedAt])
}

enum ContentStatus {
  DRAFT
  PUBLISHED
}

model SlugRedirect {
  id           String   @id @default(cuid())
  resourceType String
  oldSlug      String
  newSlug      String
  resourceId   String
  createdAt    DateTime @default(now())

  @@unique([resourceType, oldSlug])
  @@index([resourceType])
}

model PreviewToken {
  id           String   @id @default(cuid())
  token        String   @unique
  userId       String
  resourceType String
  resourceId   String
  expiresAt    DateTime
  createdAt    DateTime @default(now())
}

// Public-gallery image (separate from the case-study "Project" model).
// Curated by an admin; supports captions, optional category groups, ordering,
// and visibility toggle. Image is a Cloudinary publicId OR a /public/ URL.
model GalleryItem {
  id        String   @id @default(cuid())
  image     String
  caption   String?
  category  String?
  order     Int      @default(0)
  isVisible Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([isVisible, order])
}

// ─────────────────────────────────────────────────────────────
//  ORDERS
// ─────────────────────────────────────────────────────────────

model Order {
  id            String           @id @default(cuid())
  code          String           @unique
  userId        String
  user          User             @relation(fields: [userId], references: [id])
  customerName  String
  customerPhone String
  customerEmail String
  address       String
  area          String?
  preferredDate DateTime
  timeWindow    String
  notes         String?
  status        OrderStatus      @default(PENDING)
  subtotal      Decimal          @default(0) @db.Decimal(10, 2)
  discount      Decimal          @default(0) @db.Decimal(10, 2)
  total         Decimal          @default(0) @db.Decimal(10, 2)
  paymentStatus PaymentStatus    @default(UNPAID)
  cancelledAt   DateTime?
  cancelReason  String?
  deletedAt     DateTime?
  items         OrderItem[]
  statusLogs    OrderStatusLog[]
  createdAt     DateTime         @default(now())
  updatedAt     DateTime         @updatedAt

  @@index([userId])
  @@index([status])
  @@index([deletedAt])
  @@index([createdAt])
}

enum OrderStatus {
  PENDING
  CONFIRMED
  IN_PROGRESS
  COMPLETED
  CANCELLED
}

enum PaymentStatus {
  UNPAID
  PARTIAL
  PAID
  REFUNDED
}

model OrderItem {
  id        String  @id @default(cuid())
  orderId   String
  order     Order   @relation(fields: [orderId], references: [id], onDelete: Cascade)
  serviceId String
  service   Service @relation(fields: [serviceId], references: [id])
  quantity  Int     @default(1)
  unitPrice Decimal @db.Decimal(10, 2)
  lineTotal Decimal @db.Decimal(10, 2)
  meta      Json?
}

model OrderStatusLog {
  id         String       @id @default(cuid())
  orderId    String
  order      Order        @relation(fields: [orderId], references: [id], onDelete: Cascade)
  fromStatus OrderStatus?
  status     OrderStatus
  note       String?
  changedBy  String?
  createdAt  DateTime     @default(now())
}

// ─────────────────────────────────────────────────────────────
//  ANCILLARY
// ─────────────────────────────────────────────────────────────

model Testimonial {
  id        String   @id @default(cuid())
  name      String
  role      String?
  avatar    String?
  rating    Int      @default(5)
  body      String   @db.Text
  isVisible Boolean  @default(true)
  order     Int      @default(0)
  createdAt DateTime @default(now())
}

model Faq {
  id        String  @id @default(cuid())
  question  String
  answer    Json
  category  String?
  isVisible Boolean @default(true)
  order     Int     @default(0)
}

// ─────────────────────────────────────────────────────────────
//  MEDIA LIBRARY
// ─────────────────────────────────────────────────────────────

model MediaFolder {
  id        String        @id @default(cuid())
  name      String
  parentId  String?
  parent    MediaFolder?  @relation("MediaFolderTree", fields: [parentId], references: [id], onDelete: Cascade)
  children  MediaFolder[] @relation("MediaFolderTree")
  media     Media[]
  createdAt DateTime      @default(now())

  @@index([parentId])
}

model Media {
  id           String       @id @default(cuid())
  publicId     String       @unique
  url          String
  resourceType MediaType    @default(IMAGE)
  format       String?
  width        Int?
  height       Int?
  duration     Float?
  bytes        Int?
  folderId     String?
  folder       MediaFolder? @relation(fields: [folderId], references: [id], onDelete: SetNull)
  alt          String?
  caption      String?
  tags         String[]
  uploadedBy   String?
  createdAt    DateTime     @default(now())

  @@index([folderId])
  @@index([resourceType])
  @@index([tags])
}

enum MediaType {
  IMAGE
  VIDEO
  RAW
}

// ─────────────────────────────────────────────────────────────
//  SETTINGS & CONTACT
// ─────────────────────────────────────────────────────────────

model Setting {
  key       String   @id
  value     Json
  updatedAt DateTime @updatedAt
}

model ContactMessage {
  id               String   @id @default(cuid())
  name             String
  email            String
  phone            String?
  subject          String?
  message          String   @db.Text
  relatedOrderCode String?
  isRead           Boolean  @default(false)
  createdAt        DateTime @default(now())
}
