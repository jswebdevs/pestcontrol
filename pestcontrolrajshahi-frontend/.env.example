# ─────────────────────────────────────────────────────────────────────────────
# Pest Control Rajshahi — FRONTEND env template
# Copy to `.env.local` and fill in real values. `.env.local` is gitignored.
# Only NEXT_PUBLIC_* vars are exposed to the browser — never put secrets here.
# ─────────────────────────────────────────────────────────────────────────────

# Backend API base (must include the /api/v1 prefix).
# Dev:  http://localhost:4002/api/v1
# Prod: https://your-backend-domain.com/api/v1
NEXT_PUBLIC_API_URL=http://localhost:4002/api/v1

# Branding
NEXT_PUBLIC_SITE_NAME="Pest Control Rajshahi"

# Canonical public site URL (used for metadata / canonical / OG tags).
# Dev: http://localhost:3002   Prod: https://your-frontend-domain.com
NEXT_PUBLIC_SITE_URL=http://localhost:3002

# Cloudinary cloud name — must match the backend's CLOUDINARY_CLOUD_NAME.
NEXT_PUBLIC_CLOUDINARY_CLOUD_NAME=your_cloud_name
